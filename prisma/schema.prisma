generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RideStatus {
  pending
  accepted
  in_progress
  declined
  cancelled
  completed
}

enum PaymentMethod {
  cash
  flooz
  tmoney
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String   @unique
  createdAt DateTime @default(now())

  rides Ride[]
}

model Driver {
  id           String   @id @default(cuid())
  name         String
  phone        String   @unique
  licensePlate String
  available    Boolean  @default(false)
  lat          Float?
  lng          Float?
  createdAt    DateTime @default(now())

  rides Ride[]
}

model Ride {
  id                String         @id @default(cuid())
  customerId        String
  customer          Customer       @relation(fields: [customerId], references: [id])
  driverId          String?
  driver            Driver?        @relation(fields: [driverId], references: [id])
  originLat         Float?
  originLng         Float?
  destination       String
  estimatedPrice    Float
  distanceKm        Float?
  etaMinutes        Int?
  status            RideStatus     @default(pending)
  paymentMethod     PaymentMethod?
  declinedDriverIds String[]       @default([])
  createdAt         DateTime       @default(now())
}
